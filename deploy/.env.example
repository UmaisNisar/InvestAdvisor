# Copy to deploy/.env (gitignored). Used by ship.sh / ship.ps1.

SSH_HOST=                # e.g. 1.2.3.4 or invest.yourdomain.com
SSH_USER=root            # the user that can sudo systemctl
SSH_PORT=22
REMOTE_PATH=/opt/invest-advisor
SERVICE_NAME=invest-advisor
# Build target: linux-x64 for Intel/AMD boxes (Hetzner, GCP e2-micro);
# linux-arm64 for ARM boxes (Oracle Cloud Always Free Ampere A1).
RID=linux-x64
