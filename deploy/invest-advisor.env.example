# Copy this file to /etc/invest-advisor.env on the VPS and fill in your secrets.
# chmod 600 /etc/invest-advisor.env && chown root:root /etc/invest-advisor.env
# Then: sudo systemctl restart invest-advisor

# Anthropic Messages API key
ANTHROPIC_API_KEY=sk-ant-...

# Finnhub market data API key
FINNHUB_API_KEY=...

# SMTP password (only if you've enabled the email channel in the app's Settings page).
# The other SMTP fields (host, port, from, to, SSL) are configured via the UI.
SMTP_PASSWORD=
