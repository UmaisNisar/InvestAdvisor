# Copy this file to /etc/invest-advisor.env on the VPS and fill in your secrets.
# chmod 600 /etc/invest-advisor.env && chown root:root /etc/invest-advisor.env
# Then: sudo systemctl restart invest-advisor

# Google Gemini API key — powers the free default AI provider.
# Get a free key at https://aistudio.google.com (no billing required).
GEMINI_API_KEY=

# Anthropic Messages API key — optional, only needed if you switch the AI
# provider to Anthropic Claude (paid) in Settings → AI Provider.
ANTHROPIC_API_KEY=

# Custom OpenAI-compatible provider (Groq / OpenRouter / Ollama) — optional.
# Base URL can also be set in Settings → AI Provider.
#LLM_API_KEY=
#LLM_BASE_URL=

# Finnhub market data API key
FINNHUB_API_KEY=...

# SMTP password (only if you've enabled the email channel in the app's Settings page).
# The other SMTP fields (host, port, from, to, SSL) are configured via the UI.
SMTP_PASSWORD=
