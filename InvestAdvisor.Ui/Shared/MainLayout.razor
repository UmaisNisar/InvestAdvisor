@inherits LayoutComponentBase
@inject IPortfolioQueries Queries
@implements IDisposable
@inject IRunEventBus Bus
@inject ITenantContext Tenant

<MudLayout>
    <MudAppBar Color="Color.Default" Elevation="0">
        @* Hamburger drives the desktop drawer; on phones the bottom tab bar's "More" opens it. *@
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="ToggleDrawer" Title="Toggle menu" Class="mr-1 d-none d-md-inline-flex" />
        <MudText Typo="Typo.h6" Style="font-weight:600;letter-spacing:-.01em;">InvestAdvisor</MudText>
        <MudSpacer />
        @if (!string.IsNullOrEmpty(_email))
        {
            <MudTooltip Text="@($"Signed in as {_email}")">
                <MudChip T="string" Icon="@Icons.Material.Outlined.AccountCircle" Size="Size.Small"
                         Variant="Variant.Text" Color="Color.Default" Class="d-none d-sm-flex mr-1">@_email</MudChip>
            </MudTooltip>
        }
        <MudIconButton Icon="@(RootComponent?.IsDarkMode == true ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                       Color="Color.Inherit" Edge="Edge.End" OnClick="ToggleTheme"
                       Title="Toggle light/dark" Class="mr-2" />
        <ConnectionStatusPill />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md"
               ClipMode="DrawerClipMode.Always" Width="220px" Elevation="0">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-6">
            @Body
        </MudContainer>
    </MudMainContent>
    <BottomNav OnMore="OpenDrawer" />
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string? _email;

    [CascadingParameter] private Root? RootComponent { get; set; }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void OpenDrawer() => _drawerOpen = true;

    protected override void OnInitialized()
    {
        Bus.RunCompleted += OnRunCompleted;
    }

    protected override async Task OnInitializedAsync()
    {
        try { _email = (await Tenant.GetCurrentAsync()).Email; }
        catch { /* no authenticated user (shouldn't happen behind Cloudflare) */ }
    }

    private async Task ToggleTheme()
    {
        if (RootComponent is not null) await RootComponent.ToggleDarkModeAsync();
    }

    private void OnRunCompleted(object? sender, RunCompletedEvent e)
    {
        // Each page subscribes itself; no global state to refresh here.
    }

    public void Dispose()
    {
        Bus.RunCompleted -= OnRunCompleted;
    }
}
