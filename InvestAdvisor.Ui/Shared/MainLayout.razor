@inherits LayoutComponentBase
@inject IPortfolioQueries Queries
@implements IDisposable
@inject IRunEventBus Bus
@inject ITenantContext Tenant
@inject IJSRuntime JS

<LoadingBar />

<MudLayout>
    @* Top bar is phones-only. On desktop the left rail holds the brand, nav, theme
       and status — so we drop the top bar entirely and reclaim that vertical band. *@
    <MudAppBar Color="Color.Default" Elevation="0" Class="d-flex d-md-none">
        <MudText Typo="Typo.h6" Style="font-weight:600;letter-spacing:-.01em;">InvestAdvisor</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Outlined.Search" Color="Color.Inherit" OnClick="OpenSearch" Title="Search (⌘/Ctrl K)" Class="mr-1" />
        <MudIconButton Icon="@(RootComponent?.IsDarkMode == true ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                       Color="Color.Inherit" OnClick="ToggleTheme" Title="Toggle light/dark" Class="mr-2" />
        <ConnectionStatusPill />
    </MudAppBar>

    @* Desktop: collapsible mini (icon) ↔ full rail. Hidden on phones (CSS) — the bottom
       tab bar is the phone nav. *@
    <MudDrawer @bind-Open="_railOpen" Variant="DrawerVariant.Mini" ClipMode="DrawerClipMode.Never"
               Width="240px" MiniWidth="64px" Elevation="0" Class="ia-rail">
        <div class="ia-rail-header">
            <MudLink Href="/" Underline="Underline.None" Class="ia-rail-brand">
                @* ?v= busts browser/CDN caches when the brand mark changes (bump on icon redesigns). *@
                <img src="_content/InvestAdvisor.Ui/favicon.svg?v=mono" alt="" width="26" height="26" />
                <span class="ia-rail-brand-text">InvestAdvisor</span>
            </MudLink>
            <MudStack Row="true" Spacing="0" AlignItems="AlignItems.Center">
                <MudIconButton Icon="@Icons.Material.Outlined.Search" Size="Size.Small" OnClick="OpenSearch"
                               Title="Search (⌘/Ctrl K)" />
                <MudIconButton Icon="@(_railOpen ? Icons.Material.Filled.ChevronLeft : Icons.Material.Filled.ChevronRight)"
                               Size="Size.Small" OnClick="ToggleRail"
                               Title="@(_railOpen ? "Collapse menu" : "Expand menu")" Class="ia-rail-pin" />
            </MudStack>
        </div>

        <NavMenu />

        <div class="ia-rail-footer">
            <MudIconButton Icon="@(RootComponent?.IsDarkMode == true ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                           OnClick="ToggleTheme" Title="Toggle light/dark" Size="Size.Small" />
            @if (!string.IsNullOrEmpty(_email))
            {
                <MudTooltip Text="@($"Signed in as {_email}")">
                    <MudIconButton Icon="@Icons.Material.Outlined.AccountCircle" Size="Size.Small" />
                </MudTooltip>
            }
            <div class="ia-rail-status"><ConnectionStatusPill /></div>
        </div>
    </MudDrawer>

    @* Phones: temporary overlay opened from the bottom tab bar's "More". Hidden on desktop (CSS). *@
    <MudDrawer @bind-Open="_mobileNavOpen" Variant="DrawerVariant.Temporary" Anchor="Anchor.Start"
               ClipMode="DrawerClipMode.Never" Width="260px" Elevation="6" Class="ia-mobile-nav">
        <div class="ia-rail-header">
            <MudLink Href="/" Underline="Underline.None" Class="ia-rail-brand">
                @* ?v= busts browser/CDN caches when the brand mark changes (bump on icon redesigns). *@
                <img src="_content/InvestAdvisor.Ui/favicon.svg?v=mono" alt="" width="26" height="26" />
                <span class="ia-rail-brand-text">InvestAdvisor</span>
            </MudLink>
        </div>
        <div @onclick="CloseMobileNav"><NavMenu /></div>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-6">
            @Body
        </MudContainer>
    </MudMainContent>

    <BottomNav OnMore="OpenMobileNav" />
</MudLayout>

@* App-wide command palette + the Add-holding dialog it hands ticker picks to. *@
<GlobalSearch @ref="_search" OnAddTicker="OpenAddHolding" />
<HoldingEditDialog @ref="_holdingDialog" />

@code {
    // Desktop rail: true = full, false = mini. Starts collapsed; expanded from the saved
    // preference after first render (desktop only).
    private bool _railOpen;
    // Phone nav overlay (opened by the bottom bar's "More").
    private bool _mobileNavOpen;
    private string? _email;

    [CascadingParameter] private Root? RootComponent { get; set; }

    private void OpenMobileNav() => _mobileNavOpen = true;
    private void CloseMobileNav() => _mobileNavOpen = false;

    private GlobalSearch? _search;
    private HoldingEditDialog? _holdingDialog;
    private DotNetObjectReference<MainLayout>? _hotkeyRef;

    private void OpenSearch() => _search?.Open();

    /// <summary>Invoked by the Ctrl/Cmd+K hotkey (wired in App.razor's iaHotkeys).</summary>
    [JSInvokable]
    public Task OpenSearchFromHotkey()
    {
        _search?.Open();
        return Task.CompletedTask;
    }

    // A ticker picked in the palette opens the shared Add-holding dialog, pre-filled.
    private void OpenAddHolding(TickerSearchResult t) => _holdingDialog?.Open(new Holding
    {
        Ticker = t.Symbol,
        Name = t.Name,
        AssetClass = t.AssetClass,
        AccountType = AccountType.Taxable,
        Currency = t.Symbol.EndsWith(".TO", StringComparison.OrdinalIgnoreCase) || t.Symbol.EndsWith(".V", StringComparison.OrdinalIgnoreCase)
            ? "CAD"
            : t.Symbol.EndsWith(".AX", StringComparison.OrdinalIgnoreCase) ? "AUD" : "USD",
    });

    protected override void OnInitialized()
    {
        Bus.RunCompleted += OnRunCompleted;
    }

    protected override async Task OnInitializedAsync()
    {
        try { _email = (await Tenant.GetCurrentAsync()).Email; }
        catch { /* no authenticated user (shouldn't happen behind Cloudflare) */ }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            // Wire the Ctrl/Cmd+K search hotkey to this layout.
            _hotkeyRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("iaHotkeys.register", _hotkeyRef);

            // Only auto-expand on desktop; phones use the bottom bar + "More" overlay.
            if (await JS.InvokeAsync<bool>("iaRail.isDesktop"))
            {
                var saved = await JS.InvokeAsync<string?>("iaRail.get");
                _railOpen = saved != "collapsed"; // default expanded; respect a saved collapse
                StateHasChanged();
            }
        }
        catch { /* JS not ready / prerender — leave collapsed */ }
    }

    private async Task ToggleRail()
    {
        _railOpen = !_railOpen;
        try { await JS.InvokeVoidAsync("iaRail.set", _railOpen ? "open" : "collapsed"); }
        catch { /* persistence is best-effort */ }
    }

    private async Task ToggleTheme()
    {
        if (RootComponent is not null) await RootComponent.ToggleDarkModeAsync();
    }

    private void OnRunCompleted(object? sender, RunCompletedEvent e)
    {
        // Each page subscribes itself; no global state to refresh here.
    }

    public void Dispose()
    {
        Bus.RunCompleted -= OnRunCompleted;
        if (_hotkeyRef is not null)
        {
            try { _ = JS.InvokeVoidAsync("iaHotkeys.unregister"); } catch { }
            _hotkeyRef.Dispose();
        }
    }
}
