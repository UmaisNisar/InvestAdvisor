@using InvestAdvisor.Core.Entities
@using InvestAdvisor.Core.Enums
@inject INotificationCenter Center
@inject ITenantContext Tenant
@inject NavigationManager Nav
@implements IDisposable

@* The bell's chrome (rail + app bar) uses backdrop-filter for the glass look, which establishes a
   containing block — so a position:fixed popover anchored in the rail gets trapped and clipped to
   it. We therefore render the panel through MudPopover, whose content lives in the root popover
   provider (outside the glass), exactly like a MudMenu. But we drive Open ourselves so the card can
   play an exit animation before it unmounts: a real iOS-style open AND close. A transparent
   MudOverlay (also root-level) handles click-away. *@
<MudBadge Content="_unread" Visible="_unread > 0" Color="Color.Error" Overlap="true" Bordered="true" Class="ia-notif-badge">
    <MudIconButton Icon="@(_unread > 0 ? Icons.Material.Filled.Notifications : Icons.Material.Outlined.Notifications)"
                   Color="Color.Inherit" Size="Size.Small" aria-label="Notifications" Title="Notifications" OnClick="Toggle" />
</MudBadge>

<MudPopover Open="_popOpen" Paper="false" Fixed="false"
            AnchorOrigin="@(OpenUpward ? Origin.TopRight : Origin.BottomRight)"
            TransformOrigin="@(OpenUpward ? Origin.BottomLeft : Origin.TopRight)"
            PopoverClass="ia-notif-popover">
    @* Click-away backdrop. It lives inside the popover content (rendered in the root provider, so
       no glass ancestor) — a position:fixed full-screen catcher behind the card, which sidesteps
       MudOverlay's own z-index. *@
    <div class="ia-pop-backdrop" @onclick="Close"></div>
    <div class="ia-pop @(OpenUpward ? "ia-pop-up" : "ia-pop-down") @(_visible ? "ia-pop-open" : null)">
        <div class="ia-notif-head">
            <MudText Typo="Typo.subtitle2">Notifications</MudText>
            @if (_items.Any(n => n.ReadUtc is null))
            {
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="MarkAllRead">Mark all read</MudButton>
            }
        </div>
        <MudDivider />
        @if (_items.Count == 0)
        {
            <div class="ia-notif-empty">
                <MudIcon Icon="@Icons.Material.Outlined.NotificationsNone" Size="Size.Large" Color="Color.Default" />
                <MudText Typo="Typo.body2" Color="Color.Surface">You're all caught up</MudText>
            </div>
        }
        else
        {
            @foreach (var n in _items)
            {
                <div class="@(n.ReadUtc is null ? "ia-notif-item ia-notif-unread" : "ia-notif-item")" @onclick="@(() => OnItemClick(n))">
                    <div class="ia-notif-row">
                        <MudIcon Icon="@IconFor(n.Severity)" Color="@ColorFor(n.Severity)" Size="Size.Small" Class="ia-notif-ic" />
                        <div class="ia-notif-text">
                            <MudText Typo="Typo.body2" Style="@(n.ReadUtc is null ? "font-weight:600;" : null)">@n.Title</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Surface" Class="ia-notif-body">@n.Body</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default">@Ago(n.CreatedUtc)</MudText>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</MudPopover>

@code {
    /// <summary>When the bell sits at the bottom of the screen (desktop rail footer), open the menu upward.</summary>
    [Parameter] public bool OpenUpward { get; set; }

    // Keep in sync with the CSS exit transition duration below.
    private const int ExitMs = 200;

    private int _tenantId = -1;
    private int _unread;
    private IReadOnlyList<Notification> _items = Array.Empty<Notification>();

    // Open lifecycle. _popOpen mounts/positions the MudPopover (kept true through the exit animation);
    // _visible toggles the card's .ia-pop-open class (drives the enter/exit transition); _wantOpen is
    // the user's intent, so an in-flight close can tell whether it was re-opened mid-animation.
    private bool _popOpen;
    private bool _visible;
    private bool _wantOpen;

    protected override async Task OnInitializedAsync()
    {
        Center.NotificationsChanged += OnNotificationsChanged;
        try
        {
            _tenantId = await Tenant.GetTenantIdAsync();
            await Refresh();
        }
        catch { /* no authenticated user (shouldn't happen behind Cloudflare) */ }
    }

    // Mount the card closed, then flip to open on the next frame so the browser has a start frame to
    // transition from (mounting straight into the open state would skip the enter animation).
    protected override void OnAfterRender(bool firstRender)
    {
        if (_wantOpen && _popOpen && !_visible)
        {
            _visible = true;
            StateHasChanged();
        }
    }

    private Task Toggle() => _wantOpen ? Close() : Open();

    private async Task Open()
    {
        _wantOpen = true;
        _popOpen = true;
        _visible = false;
        await Refresh();
        StateHasChanged();
    }

    private async Task Close()
    {
        if (!_wantOpen) return;
        _wantOpen = false;
        _visible = false;       // removes .ia-pop-open → exit transition plays (popover still mounted)
        StateHasChanged();
        await Task.Delay(ExitMs);
        if (!_wantOpen)         // not re-opened mid-animation
        {
            _popOpen = false;   // now unmount the popover + overlay
            StateHasChanged();
        }
    }

    private async Task Refresh()
    {
        if (_tenantId < 0) return;
        _unread = await Center.UnreadCountAsync(_tenantId);
        _items = await Center.ListRecentAsync(_tenantId, take: 15);
    }

    // Live badge: this tenant's notifications changed (added/read elsewhere). Re-pull off the UI thread.
    private async void OnNotificationsChanged(object? sender, int tenantId)
    {
        if (tenantId != _tenantId) return;
        try
        {
            await Refresh();
            await InvokeAsync(StateHasChanged);
        }
        catch { /* component may be tearing down */ }
    }

    private async Task OnItemClick(Notification n)
    {
        if (n.ReadUtc is null)
        {
            await Center.MarkReadAsync(_tenantId, n.Id);
            await Refresh();
        }
        await Close();
        if (!string.IsNullOrWhiteSpace(n.LinkUrl)) Nav.NavigateTo(n.LinkUrl);
    }

    private async Task MarkAllRead()
    {
        await Center.MarkAllReadAsync(_tenantId);
        await Refresh();
    }

    private static string IconFor(NotificationSeverity s) => s switch
    {
        NotificationSeverity.Success => Icons.Material.Filled.CheckCircle,
        NotificationSeverity.Warning => Icons.Material.Filled.Warning,
        NotificationSeverity.Error => Icons.Material.Filled.Error,
        _ => Icons.Material.Filled.Info,
    };

    private static Color ColorFor(NotificationSeverity s) => s switch
    {
        NotificationSeverity.Success => Color.Success,
        NotificationSeverity.Warning => Color.Warning,
        NotificationSeverity.Error => Color.Error,
        _ => Color.Info,
    };

    private static string Ago(DateTime utc)
    {
        var d = DateTime.UtcNow - utc;
        if (d.TotalSeconds < 60) return "just now";
        if (d.TotalMinutes < 60) return $"{(int)d.TotalMinutes}m ago";
        if (d.TotalHours < 24) return $"{(int)d.TotalHours}h ago";
        if (d.TotalDays < 7) return $"{(int)d.TotalDays}d ago";
        return utc.ToLocalTime().ToString("MMM d");
    }

    public void Dispose() => Center.NotificationsChanged -= OnNotificationsChanged;
}
