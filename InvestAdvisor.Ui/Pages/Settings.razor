@page "/settings"
@page "/settings/{Tab}"
@inject IProfileService ProfileService
@inject IRuntimeSettingsStore SettingsStore
@inject IHoldingsService HoldingsService
@inject IHoldingsImportService HoldingsImport
@inject IActivityImportService ActivityImport
@inject IRealizedLotsService RealizedLots
@inject IPortfolioQueries PortfolioQueries
@inject ITenantContext Tenant
@inject ISnackbar Snackbar
@inject IDialogService Dialogs
@inject NavigationManager Nav
@implements IDisposable

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
    <MudText Typo="Typo.h4">Settings</MudText>
    @if (IsDirty)
    {
        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled"
                 Icon="@Icons.Material.Filled.EditNote">Unsaved changes</MudChip>
    }
</MudStack>

<MudTabs Position="Position.Top" ActivePanelIndex="_activeIndex" ActivePanelIndexChanged="OnTabChanged">
    <MudTabPanel Text="Profile">
        @if (_profile is null)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudPaper Class="pa-4" Elevation="0">
                <MudForm @ref="_profileForm" Model="@_profile" Validation="@(_profileValidator.ValidateValue)">
                    <MudTextField @bind-Value="_profile.GoalsText" For="@(() => _profile!.GoalsText)" Label="Goals" Lines="3" />
                    <MudSelect T="RiskTolerance" @bind-Value="_profile.RiskTolerance" Label="Risk tolerance">
                        @foreach (var r in Enum.GetValues<RiskTolerance>()) { <MudSelectItem Value="r">@r</MudSelectItem> }
                    </MudSelect>
                    <MudSelect T="TimeHorizon" @bind-Value="_profile.TimeHorizon" Label="Time horizon">
                        @foreach (var h in Enum.GetValues<TimeHorizon>()) { <MudSelectItem Value="h">@h</MudSelectItem> }
                    </MudSelect>
                    <MudNumericField @bind-Value="_profile.DriftPctThreshold" For="@(() => _profile!.DriftPctThreshold)" Label="Drift threshold (%)" Min="0m" Max="100m" />
                    <MudNumericField @bind-Value="_profile.SingleDayMovePctThreshold" For="@(() => _profile!.SingleDayMovePctThreshold)" Label="Single-day move threshold (%)" Min="0m" Max="100m" />
                    <MudNumericField @bind-Value="_profile.RebalanceCadenceHours" For="@(() => _profile!.RebalanceCadenceHours)" Label="Rebalance cadence (hours)" Min="1" />
                    <MudTextField @bind-Value="_profile.SystemPromptOverride" For="@(() => _profile!.SystemPromptOverride)" Label="System prompt override (blank = default)" Lines="14" />
                </MudForm>
                <MudButton OnClick="SaveProfile" Color="Color.Primary" Variant="Variant.Filled" Class="mt-2">Save profile</MudButton>
            </MudPaper>
        }
    </MudTabPanel>

    <MudTabPanel Text="Scheduler & Triggers">
        @if (_settings is null)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudPaper Class="pa-4" Elevation="0">
                <MudForm @ref="_schedulerForm" Model="@_settings" Validation="@(_settingsValidator.ValidateValue)">
                    <MudSwitch @bind-Value="_settings.AgentPaused" Label="Pause automated AI runs (worker stops triggering analyses; manual 'Run now' still works)" Color="Color.Warning" />
                    <MudNumericField @bind-Value="_settings.DailyBudgetUsd" For="@(() => _settings!.DailyBudgetUsd)" Label="Daily AI budget (USD)" Min="0" Step="0.5M" Format="F2"
                                     HelperText="Hard ceiling on AI spend per UTC day; worker runs pause when reached. Manual 'Run now' still works. 0 = unlimited." />
                    <MudNumericField @bind-Value="_settings.TickIntervalSeconds" For="@(() => _settings!.TickIntervalSeconds)" Label="Tick interval (seconds)" Min="15"
                                     HelperText="How often the background worker refreshes prices and checks your triggers." />
                    <MudSwitch @bind-Value="_settings.MarketHoursOnly" Label="Equity triggers only during NY market hours" Color="Color.Primary" />
                    <MudTextField @bind-Value="_settings.TimeZoneId" For="@(() => _settings!.TimeZoneId)" Label="Time zone ID"
                                  HelperText="IANA zone used to decide market hours, e.g. America/New_York." />
                    <MudNumericField @bind-Value="_settings.MaxRunsPerDay" For="@(() => _settings!.MaxRunsPerDay)" Label="Max runs per day" Min="1"
                                     HelperText="Safety cap on AI analysis runs per day (cost guard)." />
                    <MudNumericField @bind-Value="_settings.MinSecondsBetweenRuns" For="@(() => _settings!.MinSecondsBetweenRuns)" Label="Min seconds between runs" Min="0"
                                     HelperText="Minimum gap between AI runs, so rapid triggers don't pile up." />
                    <MudNumericField @bind-Value="_settings.MaxSnapshotAgeForTriggerSeconds" For="@(() => _settings!.MaxSnapshotAgeForTriggerSeconds)" Label="Max snapshot age for trigger (s)" Min="60"
                                     HelperText="Ignore price snapshots older than this when evaluating triggers." />
                    <MudNumericField @bind-Value="_settings.MinPriceFreshnessSeconds" For="@(() => _settings!.MinPriceFreshnessSeconds)" Label="Min price freshness (s)" Min="0"
                                     HelperText="Refresh a price if the latest snapshot is older than this." />
                </MudForm>
                <MudButton OnClick="@(() => SaveSettings(_schedulerForm))" Color="Color.Primary" Variant="Variant.Filled" Class="mt-2">Save</MudButton>
            </MudPaper>
        }
    </MudTabPanel>

    <MudTabPanel Text="AI Provider">
        @if (_settings is null)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.body2" Color="Color.Surface" Class="mb-3">
                    Which AI service powers the analyses. Google Gemini's free tier is the default —
                    it costs nothing (rate-limited per day). Changes apply to the next run, no restart needed.
                </MudText>
                <MudForm @ref="_aiForm" Model="@_settings" Validation="@(_settingsValidator.ValidateValue)">
                    <MudSelect T="string" Value="_settings.LlmProvider" ValueChanged="OnProviderChanged" Label="Provider">
                        <MudSelectItem Value="@LlmProviders.Gemini">Google Gemini (free tier)</MudSelectItem>
                        <MudSelectItem Value="@LlmProviders.Anthropic">Anthropic Claude (paid)</MudSelectItem>
                        <MudSelectItem Value="@LlmProviders.Custom">Custom OpenAI-compatible (Groq / OpenRouter / Ollama)</MudSelectItem>
                    </MudSelect>
                    <MudTextField @bind-Value="_settings.LlmModel" For="@(() => _settings!.LlmModel)" Label="Primary model"
                                  HelperText="Used for manual runs, per-stock analysis and the daily recommendation." />
                    <MudTextField @bind-Value="_settings.LlmRoutineModel" For="@(() => _settings!.LlmRoutineModel)" Label="Routine model"
                                  HelperText="Cheaper/faster model for scheduled or trigger-fired runs and batch sentiment scoring." />
                    @if (_settings.LlmProvider == LlmProviders.Custom)
                    {
                        <MudTextField @bind-Value="_settings.LlmCustomBaseUrl" For="@(() => _settings!.LlmCustomBaseUrl)" Label="Base URL (OpenAI-compatible)"
                                      Placeholder="https://api.groq.com/openai/v1/"
                                      HelperText="Groq: https://api.groq.com/openai/v1/ · OpenRouter: https://openrouter.ai/api/v1/ · Ollama: http://localhost:11434/v1/" />
                    }
                </MudForm>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
                    API keys are read from config and never stored in SQLite:
                    Gemini → <code>Llm:GeminiApiKey</code> / <code>GEMINI_API_KEY</code> (free key at <code>aistudio.google.com</code>),
                    Claude → <code>Anthropic:ApiKey</code> / <code>ANTHROPIC_API_KEY</code>,
                    custom → <code>Llm:CustomApiKey</code> / <code>LLM_API_KEY</code>.
                </MudAlert>
                <MudButton OnClick="@(() => SaveSettings(_aiForm))" Color="Color.Primary" Variant="Variant.Filled" Class="mt-2">Save</MudButton>
            </MudPaper>
        }
    </MudTabPanel>

    <MudTabPanel Text="Screener weights">
        @if (_settings is null)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudPaper Class="pa-4" Elevation="0">
                <MudText Typo="Typo.body2" Color="Color.Surface" Class="mb-3">
                    Relative importance of each factor in the screener's composite score. They don't
                    need to add up to 100 — the score normalizes by their total. Set a factor to 0 to ignore it.
                </MudText>
                <MudForm @ref="_weightsForm" Model="@_settings" Validation="@(_settingsValidator.ValidateValue)">
                    <MudNumericField @bind-Value="_settings.WeightGrowth" For="@(() => _settings!.WeightGrowth)" Label="Growth (revenue + EPS growth)" Min="0" Max="100" />
                    <MudNumericField @bind-Value="_settings.WeightValuation" For="@(() => _settings!.WeightValuation)" Label="Valuation (P/E + P/FCF, lower is better)" Min="0" Max="100" />
                    <MudNumericField @bind-Value="_settings.WeightAnalyst" For="@(() => _settings!.WeightAnalyst)" Label="Analyst (buy ratings + month-over-month trend)" Min="0" Max="100" />
                    <MudNumericField @bind-Value="_settings.WeightMomentum" For="@(() => _settings!.WeightMomentum)" Label="Momentum (13- and 26-week price return)" Min="0" Max="100" />
                    <MudNumericField @bind-Value="_settings.WeightQuality" For="@(() => _settings!.WeightQuality)" Label="Quality (debt / equity, lower is better)" Min="0" Max="100" />
                    <MudNumericField @bind-Value="_settings.WeightInsider" For="@(() => _settings!.WeightInsider)" Label="Insider (net insider buying)" Min="0" Max="100" />
                    <MudNumericField @bind-Value="_settings.WeightSentiment" For="@(() => _settings!.WeightSentiment)" Label="Sentiment (news + social media, recent)" Min="0" Max="100" />
                </MudForm>
                <MudButton OnClick="@(() => SaveSettings(_weightsForm))" Color="Color.Primary" Variant="Variant.Filled" Class="mt-2">Save weights</MudButton>
            </MudPaper>
        }
    </MudTabPanel>

    <MudTabPanel Text="Email / SMTP">
        @if (_settings is null)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudPaper Class="pa-4" Elevation="0">
                <MudForm @ref="_emailForm" Model="@_settings" Validation="@(_settingsValidator.ValidateValue)">
                    <MudSwitch @bind-Value="_settings.EmailEnabled" Label="Email notifications enabled" Color="Color.Primary" />
                    <MudTextField @bind-Value="_settings.SmtpHost" For="@(() => _settings!.SmtpHost)" Label="SMTP host" />
                    <MudNumericField @bind-Value="_settings.SmtpPort" For="@(() => _settings!.SmtpPort)" Label="SMTP port" Min="1" Max="65535" />
                    <MudSwitch @bind-Value="_settings.SmtpEnableSsl" Label="Enable TLS" Color="Color.Primary" />
                    <MudTextField @bind-Value="_settings.SmtpFrom" For="@(() => _settings!.SmtpFrom)" Label="From address" />
                    <MudTextField @bind-Value="_settings.SmtpTo" For="@(() => _settings!.SmtpTo)" Label="To address" />
                </MudForm>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
                    SMTP password is read from <code>Smtp:Password</code> via <code>dotnet user-secrets</code> or the <code>SMTP_PASSWORD</code> env var. It is never stored in SQLite.
                </MudAlert>
                <MudButton OnClick="@(() => SaveSettings(_emailForm))" Color="Color.Primary" Variant="Variant.Filled" Class="mt-2">Save</MudButton>
            </MudPaper>
        }
    </MudTabPanel>

    <MudTabPanel Text="Holdings">
        @if (_holdings is null)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudExpansionPanels Class="mb-3">
                <MudExpansionPanel Text="Import holdings from CSV (e.g. Wealthsimple export)">
                    <MudText Typo="Typo.body2" Color="Color.Surface" Class="mb-2">
                        Upload a CSV with at least a <b>ticker</b> column and a <b>quantity</b> column. Optional: average cost
                        (or book cost), account, name, asset class — headers are matched flexibly. The file becomes your
                        portfolio: rows are matched by ticker + account and updated, new ones are added, and <b>holdings not
                        in the file are removed</b>. (Auto-import below only adds/updates — it never removes.)
                    </MudText>
                    <MudFileUpload T="IBrowserFile" Accept=".csv" FilesChanged="OnImportFileSelected" MaximumFileCount="1">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.UploadFile">
                                Choose CSV & import
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>

                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.subtitle2">Auto-import (optional, ~daily)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Surface" Class="mb-2">
                        Set a <b>CSV URL</b> — e.g. a published Google Sheet that Wealthica syncs your Wealthsimple holdings
                        into — and/or a <b>file path</b> on the server. The worker re-imports them on its daily cycle.
                        Leave blank for manual-only. (A public sheet URL is link-accessible — use an unguessable link.)
                    </MudText>
                    @if (_settings is not null)
                    {
                        <MudForm @ref="_importForm" Model="@_settings" Validation="@(_settingsValidator.ValidateValue)">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                <MudTextField @bind-Value="_settings.HoldingsCsvUrl" For="@(() => _settings!.HoldingsCsvUrl)" Label="Holdings CSV URL" Placeholder="https://docs.google.com/.../export?format=csv" Class="flex-grow-1" />
                                <MudButton OnClick="ImportFromUrl" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.CloudDownload">Import now</MudButton>
                            </MudStack>
                            <MudTextField @bind-Value="_settings.HoldingsCsvPath" For="@(() => _settings!.HoldingsCsvPath)" Label="Holdings CSV file path" Placeholder="/data/wealthsimple-holdings.csv" Class="mb-2" />
                        </MudForm>
                        <MudButton OnClick="@(() => SaveSettings(_importForm))" Color="Color.Primary" Variant="Variant.Outlined">Save auto-import settings</MudButton>
                    }
                </MudExpansionPanel>
            </MudExpansionPanels>

            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-3">
                <MudText>@_holdings.Count holdings</MudText>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Filled"
                           OnClick="@(() => _holdingDialog?.Open(null))">Add holding</MudButton>
            </MudStack>
            <MudTable Items="_holdings" Dense="true" Hover="true" HorizontalScrollbar="true" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Ticker</MudTh>
                    <MudTh>Name</MudTh>
                    <MudTh>Class</MudTh>
                    <MudTh>Account</MudTh>
                    <MudTh Style="text-align:right">Qty</MudTh>
                    <MudTh Style="text-align:right">Avg cost</MudTh>
                    <MudTh Style="text-align:right">Target %</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Ticker"><code>@context.Ticker</code></MudTd>
                    <MudTd DataLabel="Name">@context.Name</MudTd>
                    <MudTd DataLabel="Class">@context.AssetClass</MudTd>
                    <MudTd DataLabel="Account">@context.AccountType</MudTd>
                    <MudTd DataLabel="Qty" Style="text-align:right">@context.Quantity</MudTd>
                    <MudTd DataLabel="Avg cost" Style="text-align:right">@context.AvgCost.ToString("C2")</MudTd>
                    <MudTd DataLabel="Target %" Style="text-align:right">@(context.TargetAllocationPct?.ToString("0.0") ?? "—")</MudTd>
                    <MudTd DataLabel="">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => _holdingDialog?.Open(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteHolding(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <MudDivider Class="my-6" />

            <MudExpansionPanels Class="mb-3">
                <MudExpansionPanel Text="Import sales from Activity CSV (realized gains)">
                    <MudText Typo="Typo.body2" Color="Color.Surface" Class="mb-2">
                        The holdings CSV above only tracks what you <b>currently own</b>. When you sell, that position
                        just disappears — and the profit you locked in would be lost. Upload your Wealthsimple
                        <b>Activity</b> export here and every <b>sell</b> is recorded as a permanent realized gain/loss.
                        Re-uploading is safe — duplicate sales are skipped.
                    </MudText>
                    <MudFileUpload T="IBrowserFile" Accept=".csv" FilesChanged="OnActivityFileSelected" MaximumFileCount="1">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.UploadFile">
                                Choose Activity CSV & import
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                </MudExpansionPanel>
            </MudExpansionPanels>

            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">Realized gains</MudText>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="@(() => _realizedDialog?.Open(null))">Add sale</MudButton>
            </MudStack>
            @if (_realizedLots is { Count: > 0 })
            {
                @* Totals across all currencies use the USD-converted figure so they line up
                   with the rest of the dashboard; the per-row table keeps native amounts. *@
                <MudPaper Class="pa-3 mb-3" Elevation="0" Outlined="true">
                    <MudStack Row="true" Justify="Justify.SpaceAround" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                        <div style="text-align:center">
                            <MudText Typo="Typo.caption" Color="Color.Surface">All-time realized P/L</MudText>
                            <MudText Typo="Typo.h6" Style="@RealizedTotalStyle">@RealizedMoney(RealizedTotalUsd)</MudText>
                        </div>
                        <MudDivider Vertical="true" FlexItem="true" />
                        <div style="text-align:center">
                            <MudText Typo="Typo.caption" Color="Color.Surface">@DateTime.UtcNow.Year realized P/L</MudText>
                            <MudText Typo="Typo.h6" Style="@RealizedYtdStyle">@RealizedMoney(RealizedYtdUsd)</MudText>
                        </div>
                        <MudDivider Vertical="true" FlexItem="true" />
                        <div style="text-align:center">
                            <MudText Typo="Typo.caption" Color="Color.Surface">Sales recorded</MudText>
                            <MudText Typo="Typo.h6">@_realizedLots.Count</MudText>
                        </div>
                    </MudStack>
                </MudPaper>
            }
            @if (_realizedLots is null || _realizedLots.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Surface" Class="mb-4">
                    No realized sales yet. Import your Activity CSV above, or add one by hand.
                </MudText>
            }
            else
            {
                <MudTable Items="_realizedLots" Dense="true" Hover="true" HorizontalScrollbar="true" Breakpoint="Breakpoint.Sm" Class="mb-4">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Ticker</MudTh>
                        <MudTh>Account</MudTh>
                        <MudTh Style="text-align:right">Qty</MudTh>
                        <MudTh Style="text-align:right">Proceeds</MudTh>
                        <MudTh Style="text-align:right">Cost</MudTh>
                        <MudTh Style="text-align:right">Realized P/L</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Date">@context.RealizedAtUtc.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
                        <MudTd DataLabel="Ticker"><code>@context.Ticker</code></MudTd>
                        <MudTd DataLabel="Account">@context.AccountType</MudTd>
                        <MudTd DataLabel="Qty" Style="text-align:right">@context.Quantity</MudTd>
                        <MudTd DataLabel="Proceeds" Style="text-align:right">@context.Proceeds.ToString("C2") @context.Currency</MudTd>
                        <MudTd DataLabel="Cost" Style="text-align:right">@context.CostBasis.ToString("C2") @context.Currency</MudTd>
                        <MudTd DataLabel="Realized P/L" Style="@($"text-align:right;font-weight:600;color:{(context.RealizedPnl >= 0 ? "var(--mud-palette-success)" : "var(--mud-palette-error)")}")">
                            @(context.RealizedPnl >= 0 ? "+" : "")@context.RealizedPnl.ToString("C2") @context.Currency
                        </MudTd>
                        <MudTd DataLabel="">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenRealizedEdit(context))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteRealizedLot(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        }
    </MudTabPanel>
</MudTabs>

<HoldingEditDialog @ref="_holdingDialog" OnSaved="ReloadAll" />
<RealizedLotEditDialog @ref="_realizedDialog" OnSaved="ReloadAll" />

@code {
    private Profile? _profile;
    private RuntimeSettings? _settings;
    private List<Holding>? _holdings;
    private IReadOnlyList<RealizedLotView>? _realizedLots;
    private HoldingEditDialog? _holdingDialog;
    private RealizedLotEditDialog? _realizedDialog;

    // One MudForm per tab so each Save validates only its own fields.
    private MudForm? _profileForm;
    private MudForm? _schedulerForm;
    private MudForm? _aiForm;
    private MudForm? _weightsForm;
    private MudForm? _emailForm;
    private MudForm? _importForm;
    private readonly ProfileValidator _profileValidator = new();
    private readonly RuntimeSettingsValidator _settingsValidator = new();

    // ───────── Realized-gains totals (USD so multi-currency lots aggregate cleanly) ─────────
    private decimal RealizedTotalUsd => _realizedLots?.Sum(l => l.RealizedPnlUsd) ?? 0m;
    private decimal RealizedYtdUsd =>
        _realizedLots?.Where(l => l.RealizedAtUtc.Year == DateTime.UtcNow.Year).Sum(l => l.RealizedPnlUsd) ?? 0m;
    private static string RealizedMoney(decimal usd) => (usd >= 0 ? "+" : "") + usd.ToString("C2") + " USD";
    private static string PnlColorStyle(decimal v) =>
        $"font-weight:600;color:{(v >= 0 ? "var(--mud-palette-success)" : "var(--mud-palette-error)")}";
    private string RealizedTotalStyle => PnlColorStyle(RealizedTotalUsd);
    private string RealizedYtdStyle => PnlColorStyle(RealizedYtdUsd);

    // ───────── Unsaved-changes tracking ─────────
    // Baselines are JSON snapshots taken at load / after each successful save; the page is
    // "dirty" while either the settings or profile form diverges from its baseline.
    private string? _settingsBaseline;
    private string? _profileBaseline;
    private IDisposable? _navGuard;

    private static string Snapshot(object? o) => o is null ? "" : System.Text.Json.JsonSerializer.Serialize(o);
    private bool IsDirty =>
        (_settings is not null && Snapshot(_settings) != _settingsBaseline) ||
        (_profile is not null && Snapshot(_profile) != _profileBaseline);

    [Parameter] public string? Tab { get; set; }
    private int _activeIndex;

    // URL slug per tab, in panel order, so each tab is deep-linkable (e.g. /settings/holdings).
    private static readonly string[] TabSlugs = { "profile", "triggers", "ai", "weights", "email", "holdings" };

    protected override async Task OnInitializedAsync()
    {
        await ReloadAll();
        // Warn before navigating away with unsaved edits. In-page tab switches (which navigate
        // to /settings/<slug> for deep-linking) are exempted inside the handler.
        _navGuard = Nav.RegisterLocationChangingHandler(OnLocationChanging);
    }

    private async ValueTask OnLocationChanging(LocationChangingContext ctx)
    {
        // Don't prompt on the deep-link tab navigations that stay on this page.
        var target = ctx.TargetLocation;
        if (target.Contains("/settings", StringComparison.OrdinalIgnoreCase)) return;
        if (!IsDirty) return;

        var leave = await Dialogs.ShowMessageBoxAsync(
            "Discard unsaved changes?",
            "You've edited settings but haven't saved. Leave this page and lose those changes?",
            yesText: "Leave", cancelText: "Stay");
        if (leave != true) ctx.PreventNavigation();
    }

    public void Dispose() => _navGuard?.Dispose();

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(Tab)) return;
        var idx = Array.IndexOf(TabSlugs, Tab.ToLowerInvariant());
        if (idx >= 0) _activeIndex = idx;
    }

    private void OnTabChanged(int index)
    {
        _activeIndex = index;
        if (index >= 0 && index < TabSlugs.Length)
            Nav.NavigateTo($"/settings/{TabSlugs[index]}", replace: true);
    }

    private void OnProviderChanged(string provider)
    {
        if (_settings is null) return;
        _settings.LlmProvider = provider;
        // Fill sensible model presets so a provider switch works out of the box; the fields stay
        // editable for anyone who wants a specific model.
        switch (provider)
        {
            case LlmProviders.Gemini:
                _settings.LlmModel = "gemini-2.5-flash";
                _settings.LlmRoutineModel = "gemini-2.5-flash-lite";
                break;
            case LlmProviders.Anthropic:
                _settings.LlmModel = "claude-sonnet-4-6";
                _settings.LlmRoutineModel = "claude-haiku-4-5";
                break;
            // Custom: leave the model fields alone — they depend entirely on the endpoint.
        }
    }

    private async Task OnImportFileSelected(IBrowserFile? file)
    {
        if (file is null) return;
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();

            // Uploaded file = the full portfolio: holdings not in it are removed (replaceExisting).
            var result = await HoldingsImport.ImportCsvAsync(await Tenant.GetTenantIdAsync(), content, replaceExisting: true);
            if (result.Errors.Count > 0)
                Snackbar.Add($"Imported {result.Added} added / {result.Updated} updated / {result.Removed} removed · {result.Errors.Count} row error(s): {result.Errors[0]}", Severity.Warning);
            else
                Snackbar.Add($"Imported: {result.Added} added, {result.Updated} updated, {result.Removed} removed, {result.Skipped} skipped.",
                    result.AnyChanges ? Severity.Success : Severity.Info);

            await ReloadAll();
        }
        catch (Exception ex) { Snackbar.Add($"Import failed: {ex.Message}", Severity.Error); }
    }

    private async Task OnActivityFileSelected(IBrowserFile? file)
    {
        if (file is null) return;
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();

            var result = await ActivityImport.ImportActivityCsvAsync(await Tenant.GetTenantIdAsync(), content);
            if (result.Errors.Count > 0)
                Snackbar.Add($"Recorded {result.Recorded} sale(s), {result.Duplicates} duplicate(s) · {result.Errors[0]}", Severity.Warning);
            else
                Snackbar.Add($"Recorded {result.Recorded} realized sale(s); {result.Duplicates} already on file.",
                    result.AnyChanges ? Severity.Success : Severity.Info);

            await ReloadAll();
        }
        catch (Exception ex) { Snackbar.Add($"Activity import failed: {ex.Message}", Severity.Error); }
    }

    private void OpenRealizedEdit(RealizedLotView v) => _realizedDialog?.Open(new RealizedLot
    {
        Id = v.Id, Ticker = v.Ticker, Name = v.Name,
        AssetClass = Enum.Parse<AssetClass>(v.AssetClass), AccountType = Enum.Parse<AccountType>(v.AccountType),
        Quantity = v.Quantity, Proceeds = v.Proceeds, CostBasis = v.CostBasis,
        Currency = v.Currency, RealizedAtUtc = v.RealizedAtUtc,
    });

    private async Task DeleteRealizedLot(RealizedLotView v)
    {
        var ok = await Dialogs.ShowMessageBoxAsync("Delete realized sale?",
            $"Remove the recorded sale of {v.Ticker} ({v.RealizedAtUtc.ToLocalTime():yyyy-MM-dd})? This only affects realized-gains history.",
            yesText: "Delete", cancelText: "Cancel");
        if (ok != true) return;
        try
        {
            await RealizedLots.DeleteAsync(v.Id);
            await ReloadAll();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task ImportFromUrl()
    {
        if (_settings is null || string.IsNullOrWhiteSpace(_settings.HoldingsCsvUrl))
        {
            Snackbar.Add("Enter a CSV URL first.", Severity.Warning);
            return;
        }
        if (!await ValidateForm(_importForm)) return;
        try
        {
            await SaveSettings(_importForm); // persist the URL/path so the daily worker uses them too
            var result = await HoldingsImport.ImportFromUrlAsync(await Tenant.GetTenantIdAsync(), _settings.HoldingsCsvUrl);
            if (result.Errors.Count > 0)
                Snackbar.Add($"Imported {result.Added} added / {result.Updated} updated · {result.Errors[0]}", Severity.Warning);
            else
                Snackbar.Add($"Imported from URL: {result.Added} added, {result.Updated} updated, {result.Skipped} skipped.",
                    result.AnyChanges ? Severity.Success : Severity.Info);
            await ReloadAll();
        }
        catch (Exception ex) { Snackbar.Add($"Import failed: {ex.Message}", Severity.Error); }
    }

    private async Task ReloadAll()
    {
        try
        {
            _profile = await ProfileService.GetAsync();
            var settings = await SettingsStore.GetAsync();
            // The store returns a cached instance; clone it so we don't mutate the cached snapshot directly.
            _settings = Clone(settings);
            _holdings = (await HoldingsService.ListAsync()).ToList();
            _realizedLots = await PortfolioQueries.GetRealizedLotsAsync();
            // Reset the dirty baselines to the freshly loaded state.
            _settingsBaseline = Snapshot(_settings);
            _profileBaseline = Snapshot(_profile);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task SaveProfile()
    {
        if (!await ValidateForm(_profileForm)) return;
        try
        {
            _profile = await ProfileService.UpdateAsync(_profile!);
            _profileBaseline = Snapshot(_profile);
            Snackbar.Add("Profile saved.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    /// <summary>Validates the given tab's form (inline messages) and snackbars if invalid.</summary>
    private async Task<bool> ValidateForm(MudForm? form)
    {
        if (form is null) return true;
        await form.ValidateAsync();
        if (form.IsValid) return true;
        Snackbar.Add("Fix the highlighted fields first.", Severity.Warning);
        return false;
    }

    private async Task SaveSettings(MudForm? form)
    {
        if (_settings is null) return;
        if (!await ValidateForm(form)) return;
        try
        {
            await SettingsStore.UpdateAsync(row =>
            {
                row.TickIntervalSeconds = _settings.TickIntervalSeconds;
                row.MarketHoursOnly = _settings.MarketHoursOnly;
                row.TimeZoneId = _settings.TimeZoneId;
                row.MaxRunsPerDay = _settings.MaxRunsPerDay;
                row.MinSecondsBetweenRuns = _settings.MinSecondsBetweenRuns;
                row.AgentPaused = _settings.AgentPaused;
                row.DailyBudgetUsd = _settings.DailyBudgetUsd;
                row.LlmProvider = _settings.LlmProvider;
                row.LlmModel = _settings.LlmModel;
                row.LlmRoutineModel = _settings.LlmRoutineModel;
                row.LlmCustomBaseUrl = _settings.LlmCustomBaseUrl;
                row.MaxSnapshotAgeForTriggerSeconds = _settings.MaxSnapshotAgeForTriggerSeconds;
                row.MinPriceFreshnessSeconds = _settings.MinPriceFreshnessSeconds;
                row.WeightValuation = _settings.WeightValuation;
                row.WeightGrowth = _settings.WeightGrowth;
                row.WeightQuality = _settings.WeightQuality;
                row.WeightAnalyst = _settings.WeightAnalyst;
                row.WeightInsider = _settings.WeightInsider;
                row.WeightMomentum = _settings.WeightMomentum;
                row.WeightSentiment = _settings.WeightSentiment;
                row.EmailEnabled = _settings.EmailEnabled;
                row.SmtpHost = _settings.SmtpHost;
                row.SmtpPort = _settings.SmtpPort;
                row.SmtpEnableSsl = _settings.SmtpEnableSsl;
                row.SmtpFrom = _settings.SmtpFrom;
                row.SmtpTo = _settings.SmtpTo;
                row.HoldingsCsvPath = _settings.HoldingsCsvPath;
                row.HoldingsCsvUrl = _settings.HoldingsCsvUrl;
            });
            _settingsBaseline = Snapshot(_settings);
            Snackbar.Add("Settings saved.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task DeleteHolding(Holding h)
    {
        var confirmed = await Dialogs.ShowMessageBoxAsync(
            "Delete holding",
            $"Remove {h.Ticker} ({h.Name}) from your portfolio? This can't be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;
        try
        {
            await HoldingsService.DeleteAsync(h.Id);
            Snackbar.Add("Holding deleted.", Severity.Success);
            await ReloadAll();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

